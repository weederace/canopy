.docker/.env
.docker/volumes/
.env

.docs/TIMELOG.md
.docs/WISHLIST.md
cmd/web/explorer/.idea
**/.DS_Store
/cmd/tps/data
temp_auto_push.bat
temp_interactive_push.bat
